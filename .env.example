# 창업노트 환경변수 예시
# 실제 값은 .env에 채운다. 로컬 테스트에서 자주 바꿀 값은 .env.local에 둔다.
# DATABASE_URL을 표준으로 사용하고 SUPABASE_DB_URL은 별칭/레거시로 취급한다.

# ============================================================
# P0 - 구현 세로 슬라이스 필수
# K-Startup 수집/정규화, 규칙 매칭, 기본 DB/API에 필요
# ============================================================
# Drizzle/앱 런타임 표준 DB URL
DATABASE_URL=

# 앱 런타임 DB connection pool 크기. 한 페이지가 여러 읽기 조회를 병렬로 수행하므로 기본 4, 허용 범위 1-8
CUNOTE_DB_MAX_CONNECTIONS=4

# Supabase direct connection 별칭. migration/doctor에서 DATABASE_URL 다음 후보로 사용
DIRECT_URL=

# 웹 세션 서명 secret
NEXTAUTH_SECRET=

# 앱 access/refresh 토큰 서명 secret
JWT_SECRET=

# 신청 캘린더 public feed token 서명 secret. 비워두면 JWT/NEXTAUTH/AUTH secret을 fallback으로 사용
CUNOTE_CALENDAR_FEED_SECRET=

# K-Startup 공고 API serviceKey
KSTARTUP_SERVICE_KEY=

# 팝빌 SecretKey
POPBILL_SECRET_KEY=

# 팝빌 SecretKey 별칭. POPBILL_SECRET_KEY와 동일 의미
POPBILL_API_KEY=

# 팝빌 LinkID
POPBILL_LINK_ID=

# 팝빌 회원 사업자번호 10자리
POPBILL_CORP_NUM=

# S0-D/로컬 테스트용 조회 대상 사업자번호
POPBILL_CHECK_CORP_NUM=
POPBILL_DEMO_CHECK_CORP_NUM=

# Popbill checkBizInfo 캐시 TTL(시간). 응답 본문 전체를 DB(company_enrichment_cache)에 영구 저장하고,
# 이 기간이 지나면 다음 조회 시 팝빌을 1회 다시 호출해 최신 상태로 갱신한다.
# 비워두면 기본 90일(2160시간). 0 이하로 두면 만료 없이 무기한 캐시(재조회/재과금 없음).
CUNOTE_POPBILL_CACHE_TTL_HOURS=

# Popbill 활성 환경. 운영 전환 시 POPBILL_ENVIRONMENT=production 및 POPBILL_IS_TEST=false로 함께 변경
POPBILL_ENVIRONMENT=test
POPBILL_BASE_URL=https://popbill-test.linkhub.co.kr
POPBILL_SERVICE_ID=POPBILL_TEST

# Popbill 환경별 API endpoint. SDK 호출은 POPBILL_IS_TEST를 사용하고, 직접 API 호출 시 아래 값을 사용
POPBILL_TEST_BASE_URL=https://popbill-test.linkhub.co.kr
POPBILL_TEST_SERVICE_ID=POPBILL_TEST
POPBILL_PRODUCTION_BASE_URL=https://popbill.linkhub.co.kr
POPBILL_PRODUCTION_SERVICE_ID=POPBILL

# Popbill 조회 실패 관리자 알림 Slack incoming webhook
# POPBILL_ALERT_SLACK_WEBHOOK_URL이 있으면 CUNOTE_ADMIN_SLACK_WEBHOOK_URL보다 우선 사용
CUNOTE_ADMIN_SLACK_WEBHOOK_URL=
POPBILL_ALERT_SLACK_WEBHOOK_URL=

# ============================================================
# P1 - MVP 연동 확장
# 소유권 검증, 기업마당, LLM 추출, 캐시/큐, 파일 저장
# ============================================================
BIZINFO_SERVICE_KEY=
NTS_VALIDATE_KEY=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_BUCKET_URL=
R2_ENDPOINT=
JUSO_API_KEY=

# HWP 첨부 변환 CLI 경로. 기본값은 PATH의 hwp5html
HWP5HTML_BIN=

# ============================================================
# P2 - 인증/상용화 게이트
# OAuth, PASS, 배포 URL, Supabase 별칭
# ============================================================
NEXT_PUBLIC_APP_URL=
NEXTAUTH_URL=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
PASS_API_KEY=
SUPABASE_DB_URL=
SUPABASE_SERVICE_ROLE_KEY=

# 운영 법무/지원 고지. 배포 환경에서는 실제 사업자/개인정보 문의 정보를 설정한다.
NEXT_PUBLIC_SERVICE_NAME=창업노트
CUNOTE_SUPPORT_EMAIL=support@changupnote.com
CUNOTE_APPLICATIONS_EMAIL=applications@changupnote.com
NEXT_PUBLIC_SUPPORT_EMAIL=support@changupnote.com
CUNOTE_PRIVACY_EMAIL=privacy@changupnote.com
CUNOTE_LEGAL_OPERATOR_NAME=
CUNOTE_PRIVACY_OFFICER_NAME=
CUNOTE_BUSINESS_REGISTRATION_NUMBER=
CUNOTE_BUSINESS_ADDRESS=
CUNOTE_MAIL_ORDER_REGISTRATION_NUMBER=
CUNOTE_LEGAL_EFFECTIVE_DATE=2026년 6월 28일
CUNOTE_TERMS_VERSION=v1.0
CUNOTE_PRIVACY_VERSION=v1.0
CUNOTE_PRIVACY_RETENTION_SUMMARY=
# 세미콜론으로 항목 구분, 파이프로 필드 구분
# CUNOTE_PRIVACY_PROCESSORS="수탁사|처리 목적|국가|보유 기간;수탁사2|처리 목적|국가|보유 기간"
# CUNOTE_PRIVACY_OVERSEAS_TRANSFERS="이전받는 자|국가|목적|이전 항목|보유 기간|문의처"
CUNOTE_PRIVACY_PROCESSORS=
CUNOTE_PRIVACY_OVERSEAS_TRANSFERS=

# Outbound email delivery. 비워두면 기존 handoff/debug 흐름만 사용한다.
# webhook은 사내 relay, Resend/SES bridge, Make/Zapier endpoint 등으로 연결할 수 있다.
CUNOTE_EMAIL_WEBHOOK_URL=
CUNOTE_EMAIL_WEBHOOK_SECRET=
CUNOTE_EMAIL_FROM=
CUNOTE_EMAIL_REPLY_TO=

# 결제/구독 상태. provider webhook/table 연결 전에는 운영 환경값으로 현재 SaaS 청구 상태를 노출한다.
# CUNOTE_BILLING_PROVIDER=toss_payments | stripe | manual | none
CUNOTE_BILLING_PROVIDER=
CUNOTE_BILLING_SUBSCRIPTION_STATUS=early_access
CUNOTE_BILLING_PLAN_CODE=early_access
CUNOTE_BILLING_PLAN_NAME=Early Access
CUNOTE_BILLING_PRICE_LABEL=월 0원
CUNOTE_BILLING_RENEWAL_LABEL=결제 연동 전
CUNOTE_BILLING_SEAT_LIMIT=5
CUNOTE_BILLING_AUTO_BILLING_ENABLED=false
CUNOTE_BILLING_INVOICES_ENABLED=false
CUNOTE_BILLING_PAYMENT_METHOD_MANAGED=false
CUNOTE_BILLING_PROVIDER_PORTAL_URL=
CUNOTE_BILLING_TRIAL_ENDS_AT=
CUNOTE_BILLING_CURRENT_PERIOD_END=
# 세미콜론으로 항목 구분
# CUNOTE_BILLING_INCLUDED_FEATURES="지원사업 매칭;신청 파이프라인;AI 초안 작성"
# CUNOTE_BILLING_NEXT_STEPS="좌석 변경은 운영팀에 문의;영수증은 provider 포털에서 확인"
CUNOTE_BILLING_INCLUDED_FEATURES=
CUNOTE_BILLING_NEXT_STEPS=
CUNOTE_BILLING_PAYMENT_INSTRUCTIONS=
CUNOTE_BILLING_EMAIL=billing@changupnote.com
TOSS_PAYMENTS_SECRET_KEY=
STRIPE_SECRET_KEY=
CUNOTE_BILLING_WEBHOOK_SECRET=
TOSS_PAYMENTS_WEBHOOK_SECRET=
STRIPE_WEBHOOK_SECRET=

# ============================================================
# Local/dev runtime gates
# 로컬 세로 슬라이스, DB 부트스트랩, smoke 검증 재현용
# ============================================================
# runtime: 메모리/샘플 기반, drizzle: DATABASE_URL 기반 저장소
CUNOTE_REPOSITORY_ADAPTER=runtime

# auto: 키가 있으면 live 시도 후 sample fallback, sample: 샘플 고정
CUNOTE_WEB_DATA_SOURCE=sample
CUNOTE_WEB_INCLUDE_BIZINFO_SAMPLE=true

# mock: 개발용 세션/회사 접근 허용, nextauth: 실제 NextAuth 세션
CUNOTE_AUTH_MODE=mock
CUNOTE_AUTH_REQUIRED=false
CUNOTE_AUTH_DB_ADAPTER=

# 개발용 app auth/company verify 게이트. production에서는 외부 검증기 전까지 501 유지
CUNOTE_APP_AUTH_ALLOW_DEV_LOGIN=true
CUNOTE_APP_AUTH_ALLOW_DEV_OAUTH=true
CUNOTE_COMPANY_VERIFY_ALLOW_DEV=true

# 데모 사용자/회사 seed와 runtime adapter 기본값
CUNOTE_MOCK_USER_ID=00000000-0000-4000-8000-000000000001
CUNOTE_MOCK_USER_EMAIL=demo@changupnote.com
CUNOTE_MOCK_USER_NAME=창업노트 데모
CUNOTE_DEMO_COMPANY_ID=00000000-0000-4000-8000-000000000101
CUNOTE_DEMO_COMPANY_NAME=샘플 기업

# 어드민 로컬 접근. demo면 별도 세션 없이 admin surface 확인 가능
CUNOTE_ADMIN_MODE=
CUNOTE_ADMIN_USER_IDS=
CUNOTE_ADMIN_EMAILS=
CUNOTE_OPS_ADMIN_ORIGIN=https://ops.changupnote.com

# ops.changupnote.com 별도 운영자 사이트. 사용자 프론트 NEXTAUTH 세션과 공유하지 않는다.
ADMIN_AUTH_URL=https://ops.changupnote.com
ADMIN_AUTH_SECRET=
ADMIN_GOOGLE_CLIENT_ID=
ADMIN_GOOGLE_CLIENT_SECRET=
ADMIN_ALLOWED_GOOGLE_DOMAIN=noten.im
ADMIN_ALLOWED_EMAILS=
ADMIN_SESSION_COOKIE_NAME=__Secure-cunote-admin.session-token
ADMIN_CSRF_COOKIE_NAME=__Host-cunote-admin.csrf-token
CUNOTE_ADMIN_DB_MAX_CONNECTIONS=4

# guarded DB bootstrap. 실제 개발 DB가 맞을 때만 dev로 설정
CUNOTE_DB_BOOTSTRAP_CONFIRM=

# ingestion/publish dry-run controls
CUNOTE_INGEST_SOURCE=sample
CUNOTE_INGEST_DRY_RUN=false
KSTARTUP_PAGE=1
KSTARTUP_PER_PAGE=20
CUNOTE_DEDUP_DRY_RUN=false
CUNOTE_DEDUP_LIMIT=500
CUNOTE_DEDUP_MIN_SCORE=
CUNOTE_DEDUP_AS_OF=
CUNOTE_MATCH_STATE_REFRESH_LIMIT=500
CUNOTE_MATCH_STATE_REFRESH_AS_OF=
CUNOTE_MATCH_STATE_REFRESH_WRITE=false

# HTTP smoke
CUNOTE_HTTP_VERIFY_BASE_URL=http://127.0.0.1:4010
CUNOTE_HTTP_VERIFY_EMAIL=demo@changupnote.com

# ============================================================
# Popbill SDK options
# 로컬 기본값은 .env.local에서 오버라이드
# 테스트: POPBILL_IS_TEST=true, 운영: POPBILL_IS_TEST=false
# ============================================================
POPBILL_USER_ID=
POPBILL_IS_TEST=true
POPBILL_IP_RESTRICT_ON_OFF=true
POPBILL_USE_STATIC_IP=false
POPBILL_USE_LOCAL_TIME_YN=true
