# 창업노트 환경변수 예시
# 실제 값은 .env에 채운다. 로컬 테스트에서 자주 바꿀 값은 .env.local에 둔다.
# DATABASE_URL을 표준으로 사용하고 SUPABASE_DB_URL은 별칭/레거시로 취급한다.

# ============================================================
# P0 - 구현 세로 슬라이스 필수
# K-Startup 수집/정규화, 규칙 매칭, 기본 DB/API에 필요
# ============================================================
# Drizzle/앱 런타임 표준 DB URL
DATABASE_URL=

# 웹 세션 서명 secret
NEXTAUTH_SECRET=

# 앱 access/refresh 토큰 서명 secret
JWT_SECRET=

# K-Startup 공고 API serviceKey
KSTARTUP_SERVICE_KEY=

# 팝빌 SecretKey
POPBILL_SECRET_KEY=

# 팝빌 SecretKey 별칭. POPBILL_SECRET_KEY와 동일 의미
POPBILL_API_KEY=

# 팝빌 LinkID
POPBILL_LINK_ID=

# 팝빌 회원 사업자번호 10자리
POPBILL_CORP_NUM=

# S0-D/로컬 테스트용 조회 대상 사업자번호
POPBILL_CHECK_CORP_NUM=
POPBILL_DEMO_CHECK_CORP_NUM=

# ============================================================
# P1 - MVP 연동 확장
# 소유권 검증, 기업마당, LLM 추출, 캐시/큐, 파일 저장
# ============================================================
BIZINFO_SERVICE_KEY=
NTS_VALIDATE_KEY=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
JUSO_API_KEY=

# ============================================================
# P2 - 인증/상용화 게이트
# OAuth, PASS, 배포 URL, Supabase 별칭
# ============================================================
NEXT_PUBLIC_APP_URL=
NEXTAUTH_URL=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
PASS_API_KEY=
SUPABASE_DB_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ============================================================
# Popbill SDK options
# 로컬 기본값은 .env.local에서 오버라이드
# ============================================================
POPBILL_USER_ID=
POPBILL_IS_TEST=true
POPBILL_IP_RESTRICT_ON_OFF=true
POPBILL_USE_STATIC_IP=false
POPBILL_USE_LOCAL_TIME_YN=true
