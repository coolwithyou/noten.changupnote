{
  "name": "@cunote/conversion",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./convert-document": {
      "types": "./dist/convert-document.d.ts",
      "default": "./dist/convert-document.js"
    },
    "./quality": {
      "types": "./dist/quality.d.ts",
      "default": "./dist/quality.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test:quality": "node scripts/quality-test.mjs",
    "test:hwpx": "node scripts/hwpx-convert-test.mjs",
    "test:failure": "node scripts/failure-path-test.mjs",
    "test:failure:api": "node scripts/verify-failure-api.mjs",
    "test:failure:db": "node scripts/verify-failure-e2e-db.mjs",
    "test:t9": "node scripts/failure-path-test.mjs && node scripts/verify-failure-api.mjs && node scripts/verify-failure-e2e-db.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@cunote/core": "workspace:*"
  }
}
