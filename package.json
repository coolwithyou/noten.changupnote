{
  "name": "cunote",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.30.1",
  "scripts": {
    "dev:web": "node scripts/dev-web.mjs",
    "build:packages": "pnpm --filter @cunote/contracts build && pnpm --filter @cunote/core build",
    "build:web": "pnpm build:packages && pnpm --filter @cunote/web build",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "typecheck": "pnpm build:packages && tsc -p tsconfig.json --noEmit && pnpm --filter @cunote/web typecheck",
    "fetch:bizinfo": "tsx packages/core/scripts/fetch-bizinfo-live.ts",
    "fetch:kstartup": "tsx packages/core/scripts/fetch-kstartup-live.ts",
    "match:live": "tsx packages/core/scripts/match-live-company.ts",
    "prepare:bizinfo": "tsx packages/core/scripts/prepare-bizinfo-extract-input.ts",
    "convert:bizinfo-attachment": "tsx packages/core/scripts/convert-bizinfo-attachment-live.ts",
    "verify:company-profile": "tsx packages/core/scripts/verify-company-profile.ts",
    "verify:openapi": "tsx packages/contracts/scripts/verify-openapi.ts",
    "verify:bizinfo": "tsx packages/core/scripts/verify-bizinfo-fetch.ts",
    "verify:kstartup": "tsx packages/core/scripts/verify-kstartup-slice.ts",
    "test": "pnpm typecheck && pnpm verify:openapi && pnpm verify:kstartup && pnpm verify:bizinfo && pnpm verify:company-profile"
  },
  "devDependencies": {
    "@types/node": "^24.0.4",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  },
  "pnpm": {
    "overrides": {
      "popbill@1.64.2>popbill": "-"
    }
  }
}
