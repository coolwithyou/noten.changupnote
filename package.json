{
  "name": "cunote",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.30.1",
  "scripts": {
    "dev:web": "node scripts/dev-web.mjs",
    "build:packages": "pnpm --filter @cunote/contracts build && pnpm --filter @cunote/core build",
    "build:web": "pnpm build:packages && pnpm --filter @cunote/web build",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:doctor": "tsx apps/web/src/lib/server/db/doctor.ts",
    "db:bootstrap:dev": "node scripts/bootstrap-dev-db.mjs",
    "seed:demo": "tsx apps/web/src/lib/server/db/seed-demo.ts",
    "smoke:db": "tsx apps/web/src/lib/server/db/smoke-drizzle-service.ts",
    "db:studio": "drizzle-kit studio",
    "typecheck": "pnpm build:packages && tsc -p tsconfig.json --noEmit && pnpm --filter @cunote/web typecheck",
    "fetch:bizinfo": "tsx packages/core/scripts/fetch-bizinfo-live.ts",
    "fetch:kstartup": "tsx packages/core/scripts/fetch-kstartup-live.ts",
    "match:live": "tsx packages/core/scripts/match-live-company.ts",
    "match:transitions:plan": "tsx --tsconfig apps/web/tsconfig.json apps/web/src/lib/server/matches/plan-match-transitions-cli.ts",
    "openapi:export": "pnpm --filter @cunote/contracts export:openapi",
    "publish:bizinfo": "tsx apps/web/src/lib/server/ingestion/publish-bizinfo.ts",
    "publish:kstartup": "tsx apps/web/src/lib/server/ingestion/publish-kstartup.ts",
    "prepare:bizinfo": "tsx packages/core/scripts/prepare-bizinfo-extract-input.ts",
    "convert:bizinfo-attachment": "tsx packages/core/scripts/convert-bizinfo-attachment-live.ts",
    "verify:company-profile": "tsx packages/core/scripts/verify-company-profile.ts",
    "verify:dedup": "tsx packages/core/scripts/verify-dedup-candidates.ts",
    "verify:dedup-publish": "tsx --tsconfig apps/web/tsconfig.json apps/web/src/lib/server/ingestion/verify-dedup-link-publish.ts",
    "verify:matching-eval": "tsx packages/core/scripts/verify-matching-eval.ts",
    "verify:match-state-refresh": "tsx packages/core/scripts/verify-match-state-refresh.ts",
    "verify:service-usecases": "tsx packages/core/scripts/verify-service-usecases.ts",
    "verify:match-transitions": "tsx --tsconfig apps/web/tsconfig.json apps/web/src/lib/server/matches/verify-match-transitions.ts",
    "verify:web-http": "tsx apps/web/src/lib/server/verify-web-http.ts",
    "verify:db-doctor": "tsx apps/web/src/lib/server/db/doctor.ts --dry-run",
    "verify:db-bootstrap-plan": "node scripts/bootstrap-dev-db.mjs --dry-run",
    "verify:db-smoke-plan": "tsx apps/web/src/lib/server/db/smoke-drizzle-service.ts --dry-run",
    "verify:demo-seed": "tsx apps/web/src/lib/server/db/seed-demo.ts --dry-run",
    "verify:bizinfo-publish": "tsx apps/web/src/lib/server/ingestion/verify-bizinfo-publish.ts",
    "verify:ingestion-publish": "tsx apps/web/src/lib/server/ingestion/verify-kstartup-publish.ts",
    "verify:grant-criteria-schema": "tsx packages/contracts/scripts/verify-grant-criteria-schema.ts",
    "verify:openapi": "tsx packages/contracts/scripts/verify-openapi.ts",
    "verify:package-boundaries": "tsx packages/contracts/scripts/verify-package-boundaries.ts",
    "verify:route-policy": "tsx packages/contracts/scripts/verify-route-policy.ts",
    "verify:admin-routes": "tsx packages/contracts/scripts/verify-admin-routes.ts",
    "verify:runtime-repositories": "tsx --tsconfig apps/web/tsconfig.json apps/web/src/lib/server/repositories/verify-runtime-repositories.ts",
    "verify:app-auth": "tsx --tsconfig apps/web/tsconfig.json apps/web/src/lib/server/auth/verify-app-auth.ts",
    "verify:company-access": "tsx apps/web/src/lib/server/auth/verify-company-access.ts",
    "verify:company-enrichment": "tsx --tsconfig apps/web/tsconfig.json apps/web/src/lib/server/verify-company-enrichment.ts",
    "verify:web-regions": "tsx --tsconfig apps/web/tsconfig.json apps/web/src/lib/verify-web-regions.ts",
    "verify:service-data": "tsx --tsconfig apps/web/tsconfig.json apps/web/src/lib/server/verify-service-data.ts",
    "verify:consent-store": "tsx --tsconfig apps/web/tsconfig.json apps/web/src/lib/server/consents/verify-consent-store.ts",
    "verify:rls-context": "tsx packages/contracts/scripts/verify-rls-context.ts",
    "verify:rls-policy": "tsx packages/contracts/scripts/verify-rls-policy.ts",
    "verify:bizinfo": "tsx packages/core/scripts/verify-bizinfo-fetch.ts",
    "verify:kstartup": "tsx packages/core/scripts/verify-kstartup-slice.ts",
    "test": "pnpm typecheck && pnpm verify:openapi && pnpm verify:grant-criteria-schema && pnpm verify:route-policy && pnpm verify:admin-routes && pnpm verify:package-boundaries && pnpm verify:company-access && pnpm verify:company-enrichment && pnpm verify:web-regions && pnpm verify:service-data && pnpm verify:consent-store && pnpm verify:runtime-repositories && pnpm verify:app-auth && pnpm verify:rls-context && pnpm verify:rls-policy && pnpm verify:kstartup && pnpm verify:dedup && pnpm verify:matching-eval && pnpm verify:service-usecases && pnpm verify:match-transitions && pnpm verify:demo-seed && pnpm verify:db-doctor && pnpm verify:db-bootstrap-plan && pnpm verify:db-smoke-plan && pnpm verify:ingestion-publish && pnpm verify:bizinfo-publish && pnpm verify:bizinfo && pnpm verify:company-profile"
  },
  "devDependencies": {
    "@types/node": "^24.0.4",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  },
  "pnpm": {
    "overrides": {
      "popbill@1.64.2>popbill": "-"
    }
  }
}
