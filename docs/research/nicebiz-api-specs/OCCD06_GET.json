{
 "summary": "[기업]신용-법정관리/워크아웃정보",
 "operationId": "OCCD06_prime_/api/opengate/{ver}/company/credit/{companyKey}/workout",
 "parameters": [
  {
   "name": "client-id",
   "in": "header",
   "description": "클라이언트ID",
   "required": true,
   "schema": {
    "type": "string"
   }
  },
  {
   "name": "client-secret",
   "in": "header",
   "description": "클라이언트 Secret",
   "required": true,
   "schema": {
    "type": "string"
   }
  },
  {
   "name": "companyKey",
   "in": "path",
   "description": "조회할 기업의 사업자번호, 법인번호, 업체코드 중 한개만 입력",
   "required": true,
   "schema": {
    "maxLength": 13.0,
    "pattern": "\\d{10}|\\d{13}|\\w{6}",
    "type": "string",
    "description": "조회 companyKey",
    "example": "1168115020"
   }
  },
  {
   "name": "pageNo",
   "in": "query",
   "description": "Page 옵션선택 : 페이지 번호",
   "required": false,
   "schema": {
    "minimum": 1.0,
    "type": "integer",
    "description": "PageNo",
    "format": "int32",
    "default": 1.0
   }
  },
  {
   "name": "pageSize",
   "in": "query",
   "description": "Page 옵션선택 : 페이지 사이즈",
   "required": false,
   "schema": {
    "maximum": 100.0,
    "minimum": 1.0,
    "type": "integer",
    "description": "PageSize",
    "format": "int32",
    "default": 20.0
   }
  }
 ],
 "responses": {
  "200": {
   "content": {
    "application/json": {
     "schema": {
      "type": "object",
      "properties": {
       "request": {
        "required": [
         "requestedKey",
         "requestedKeyType"
        ],
        "type": "object",
        "properties": {
         "requestedKey": {
          "maxLength": 13.0,
          "type": "string",
          "description": "요청 companyKey",
          "example": "1168115020"
         },
         "requestedKeyType": {
          "maxLength": 6.0,
          "type": "string",
          "description": "요청 Key 타입(bizno, crpno, upchecd)",
          "example": "bizno",
          "enum": [
           "BIZNO",
           "UPCHECD",
           "CRPNO"
          ]
         },
         "pageNo": {
          "minimum": 1.0,
          "type": "integer",
          "description": "PageNo",
          "format": "int32",
          "example": 1.0,
          "default": 1.0
         },
         "pageSize": {
          "maximum": 100.0,
          "minimum": 1.0,
          "type": "integer",
          "description": "PageSize",
          "format": "int32",
          "example": 20.0,
          "default": 20.0
         }
        },
        "description": "기업 신용 법정관리/워크아웃정보 요청항목"
       },
       "data": {
        "required": [
         "creditWorkoutList",
         "listCount"
        ],
        "type": "object",
        "properties": {
         "message": {
          "type": "string",
          "description": "List 설명(데이터가 존재하지 않을 경우 등 이벤트 발생시 노출)",
          "example": "데이터가 존재하지 않습니다."
         },
         "totalCount": {
          "type": "integer",
          "description": "전체건수: Page 옵션 사용시 결과출력",
          "format": "int32",
          "readOnly": true,
          "example": 1.0
         },
         "listCount": {
          "maximum": 100.0,
          "type": "integer",
          "description": "List 건수",
          "format": "int32",
          "example": 1.0,
          "default": 20.0
         },
         "creditWorkoutList": {
          "type": "array",
          "description": "기업 신용 법정관리/워크아웃정보",
          "items": {
           "required": [
            "lglmgmtRldDate",
            "lglmgmtdivcd",
            "upchecd"
           ],
           "type": "object",
           "properties": {
            "upchecd": {
             "maxLength": 6.0,
             "minLength": 6.0,
             "type": "string",
             "description": "업체코드",
             "example": "ZZZZZZ"
            },
            "lglmgmtRldDate": {
             "maxLength": 8.0,
             "minLength": 8.0,
             "type": "string",
             "description": "법정관리관계일자",
             "format": "date-yyyymmdd",
             "example": "20230206"
            },
            "hngno": {
             "maxLength": 14.0,
             "type": "string",
             "description": "사건번호",
             "nullable": true,
             "example": "2022하합111"
            },
            "lwccd": {
             "maxLength": 3.0,
             "type": "string",
             "description": "법원코드",
             "nullable": true,
             "example": "504"
            },
            "lwcnm": {
             "maxLength": 100.0,
             "type": "string",
             "description": "법원명",
             "nullable": true,
             "example": "테스트법원"
            },
            "crgJudgDeptnm": {
             "maxLength": 30.0,
             "type": "string",
             "description": "담당판사부서명",
             "nullable": true,
             "example": "테스트부"
            },
            "crgJudgNam": {
             "maxLength": 100.0,
             "type": "string",
             "description": "담당판사명",
             "nullable": true,
             "example": "테스트"
            },
            "korentrnm": {
             "maxLength": 100.0,
             "type": "string",
             "description": "업체명",
             "nullable": true,
             "example": "(주)테스트"
            },
            "lglmgmtdivcd": {
             "maxLength": 2.0,
             "minLength": 2.0,
             "type": "string",
             "description": "법정관리유형코드",
             "example": "70"
            },
            "lglmgmtdivnm": {
             "maxLength": 150.0,
             "type": "string",
             "description": "법정관리유형명",
             "nullable": true,
             "example": "파산선고결정공고"
            }
           },
           "description": "법정관리/워크아웃 VO"
          }
         }
        },
        "description": "기업 신용 법정관리/워크아웃정보 결과"
       }
      }
     }
    }
   }
  }
 },
 "x-inzent-id": "86aca7a5-ccb7-46dc-a95a-6efc4e60b356"
}