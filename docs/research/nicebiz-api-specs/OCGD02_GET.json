{
 "summary": "[기업]등급-WATCH등급",
 "operationId": "OCGD02_prime_/api/opengate/{ver}/company/grade/{companyKey}/watch",
 "parameters": [
  {
   "name": "client-id",
   "in": "header",
   "description": "클라이언트ID",
   "required": true,
   "schema": {
    "type": "string"
   }
  },
  {
   "name": "client-secret",
   "in": "header",
   "description": "클라이언트 Secret",
   "required": true,
   "schema": {
    "type": "string"
   }
  },
  {
   "name": "addWatchRsn",
   "in": "query",
   "description": "WATCH 등급 사유 추가여부(true : 추가 / false: 제외)",
   "required": false,
   "schema": {
    "type": "boolean",
    "description": "WATCH 등급 사유 추가여부",
    "default": true
   }
  },
  {
   "name": "companyKey",
   "in": "path",
   "description": "조회할 기업의 사업자번호, 법인번호, 업체코드 중 한개만 입력",
   "required": true,
   "schema": {
    "maxLength": 13.0,
    "pattern": "\\d{10}|\\d{13}|\\w{6}",
    "type": "string",
    "description": "조회 companyKey",
    "example": "1168115020"
   }
  },
  {
   "name": "startDate",
   "in": "query",
   "description": "일자 옵션선택 : 조회 시작일자(startDate <= 조건)",
   "required": false,
   "schema": {
    "maxLength": 8.0,
    "minLength": 8.0,
    "type": "string",
    "description": "일자 옵션선택 : 조회 시작일자(기준일자 필드의 <= 조건)",
    "format": "date-yyyymmdd"
   }
  },
  {
   "name": "endDate",
   "in": "query",
   "description": "일자 옵션선택 : 조회 종료일자(endDate >= 조건)",
   "required": false,
   "schema": {
    "maxLength": 8.0,
    "minLength": 8.0,
    "type": "string",
    "description": "일자 옵션선택 : 조회 종료일자(기준일자 필드의 >= 조건)",
    "format": "date-yyyymmdd"
   }
  },
  {
   "name": "pageNo",
   "in": "query",
   "description": "Page 옵션선택 : 페이지 번호",
   "required": false,
   "schema": {
    "minimum": 1.0,
    "type": "integer",
    "description": "PageNo",
    "format": "int32",
    "default": 1.0
   }
  },
  {
   "name": "pageSize",
   "in": "query",
   "description": "Page 옵션선택 : 페이지 사이즈",
   "required": false,
   "schema": {
    "maximum": 100.0,
    "minimum": 1.0,
    "type": "integer",
    "description": "PageSize",
    "format": "int32",
    "default": 20.0
   }
  }
 ],
 "responses": {
  "200": {
   "content": {
    "application/json": {
     "schema": {
      "type": "object",
      "properties": {
       "request": {
        "required": [
         "requestedKey",
         "requestedKeyType"
        ],
        "type": "object",
        "properties": {
         "requestedKey": {
          "maxLength": 13.0,
          "type": "string",
          "description": "요청 companyKey",
          "example": "1168115020"
         },
         "requestedKeyType": {
          "maxLength": 6.0,
          "type": "string",
          "description": "요청 Key 타입(bizno, crpno, upchecd)",
          "example": "bizno",
          "enum": [
           "BIZNO",
           "UPCHECD",
           "CRPNO"
          ]
         },
         "addWatchRsn": {
          "type": "boolean",
          "description": "WATCH 등급 사유 추가여부",
          "default": true
         },
         "startDate": {
          "maxLength": 8.0,
          "minLength": 8.0,
          "type": "string",
          "description": "일자 옵션선택 : 조회 시작일자(기준일자 필드의 <= 조건)",
          "format": "date-yyyymmdd"
         },
         "endDate": {
          "maxLength": 8.0,
          "minLength": 8.0,
          "type": "string",
          "description": "일자 옵션선택 : 조회 종료일자(기준일자 필드의 >= 조건)",
          "format": "date-yyyymmdd"
         },
         "pageNo": {
          "minimum": 1.0,
          "type": "integer",
          "description": "PageNo",
          "format": "int32",
          "example": 1.0,
          "default": 1.0
         },
         "pageSize": {
          "maximum": 100.0,
          "minimum": 1.0,
          "type": "integer",
          "description": "PageSize",
          "format": "int32",
          "example": 20.0,
          "default": 20.0
         }
        },
        "description": "WATCH등급 요청항목"
       },
       "data": {
        "required": [
         "listCount",
         "watchList"
        ],
        "type": "object",
        "properties": {
         "message": {
          "type": "string",
          "description": "List 설명(데이터가 존재하지 않을 경우 등 이벤트 발생시 노출)"
         },
         "totalCount": {
          "type": "integer",
          "description": "전체건수: Page 옵션 사용시 결과출력",
          "format": "int32",
          "readOnly": true,
          "example": 86.0
         },
         "listCount": {
          "maximum": 100.0,
          "type": "integer",
          "description": "List 건수",
          "format": "int32",
          "example": 20.0,
          "default": 20.0
         },
         "watchList": {
          "type": "array",
          "description": "WATCH 등급 정보",
          "items": {
           "required": [
            "bizno",
            "watchBseDate"
           ],
           "type": "object",
           "properties": {
            "bizno": {
             "maxLength": 10.0,
             "minLength": 10.0,
             "type": "string",
             "description": "사업자등록번호",
             "example": "1168115020"
            },
            "watchBseDate": {
             "maxLength": 8.0,
             "minLength": 8.0,
             "type": "string",
             "description": "WATCH 경보일자(조회기준일자)",
             "format": "date-yyyymmdd",
             "example": "20230310"
            },
            "watchGrd": {
             "maxLength": 10.0,
             "type": "string",
             "description": "WATCH 등급",
             "nullable": true,
             "example": "00"
            },
            "watchGrdnm": {
             "maxLength": 150.0,
             "type": "string",
             "description": "WATCH 등급명",
             "nullable": true,
             "example": "산출유보"
            },
            "watchGrdEngnm": {
             "maxLength": 150.0,
             "type": "string",
             "description": "WATCH 등급영문명",
             "nullable": true
            },
            "watchGrdAdtndsc": {
             "maxLength": 250.0,
             "type": "string",
             "description": "WATCH 등급 부가설명",
             "nullable": true,
             "example": "기업정보 미비 또는 당사와 특수관계자에 해당하여 평가를 유보하는 기업"
            },
            "watchRsnList": {
             "type": "array",
             "description": "WATCH 등급사유 리스트",
             "items": {
              "type": "object",
              "properties": {
               "watchRsncd": {
                "maxLength": 3.0,
                "minLength": 3.0,
                "type": "string",
                "description": "WATCH 사유코드",
                "nullable": true,
                "example": "017"
               },
               "watchRsnnm": {
                "maxLength": 200.0,
                "type": "string",
                "description": "WATCH 사유명",
                "nullable": true,
                "example": "투자주의종목"
               },
               "watchRsnEngnm": {
                "maxLength": 150.0,
                "type": "string",
                "description": "WATCH 사유코드 영문명",
                "nullable": true,
                "example": "Attention to investment"
               },
               "watchRsnDatMdmCfcnm": {
                "maxLength": 150.0,
                "type": "string",
                "description": "WATCH 사유데이터 중분류명",
                "nullable": true,
                "example": "공시정보"
               },
               "watchRsnDatLargeCfcnm": {
                "maxLength": 150.0,
                "type": "string",
                "description": "WATCH 사유데이터 대분류명",
                "nullable": true,
                "example": "공시정보"
               }
              },
              "description": "WATCH 사유 VO"
             }
            }
           },
           "description": "WATCH 등급 + 사유 Collection VO"
          }
         }
        },
        "description": "기업 등급정보 Watch등급과 사유 결과"
       }
      }
     }
    }
   }
  }
 },
 "x-inzent-id": "13af6e6a-b82f-4bba-b510-afb3b28a23b7"
}