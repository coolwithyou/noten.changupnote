{
 "summary": "[기업]현황-주요주주현황",
 "operationId": "OCST02_prime_/api/opengate/{ver}/company/state/{companyKey}/shareholders",
 "parameters": [
  {
   "name": "client-id",
   "in": "header",
   "description": "클라이언트ID",
   "required": true,
   "schema": {
    "type": "string"
   }
  },
  {
   "name": "client-secret",
   "in": "header",
   "description": "클라이언트 Secret",
   "required": true,
   "schema": {
    "type": "string"
   }
  },
  {
   "name": "tpCd",
   "in": "query",
   "description": "회계기준 구분(KGAAP(01), IFRS(02))",
   "required": false,
   "schema": {
    "maxLength": 2.0,
    "type": "string",
    "description": "회계기준 구분(KGAAP(01), IFRS(02))",
    "enum": [
     "01",
     "02"
    ]
   }
  },
  {
   "name": "companyKey",
   "in": "path",
