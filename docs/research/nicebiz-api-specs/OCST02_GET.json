   "required": true,
   "schema": {
    "maxLength": 13.0,
    "pattern": "\\d{10}|\\d{13}|\\w{6}",
    "type": "string",
    "description": "조회 companyKey",
    "example": "1168115020"
   }
  },
  {
   "name": "baseDate",
   "in": "query",
   "description": "일자 옵션선택 : 조회 기준일자",
   "required": false,
