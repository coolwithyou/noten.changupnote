    "maxLength": 8.0,
    "minLength": 8.0,
    "type": "string",
    "description": "일자 옵션선택 : 조회 기준일자",
    "format": "date-yyyymmdd"
   }
  },
  {
   "name": "pageNo",
   "in": "query",
   "description": "Page 옵션선택 : 페이지 번호",
   "required": false,
   "schema": {
    "minimum": 1.0,
    "type": "integer",
    "description": "PageNo",
    "format": "int32",
    "default": 1.0
   }
  },
  {
   "name": "pageSize",
   "in": "query",
   "description": "Page 옵션선택 : 페이지 사이즈",
   "required": false,
   "schema": {
    "maximum": 100.0,
    "minimum": 1.0,
    "type": "integer",
    "description": "PageSize",
    "format": "int32",
    "default": 20.0
   }
  }
 ],
