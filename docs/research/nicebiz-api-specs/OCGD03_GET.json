{
 "summary": "[기업]등급-현금흐름등급",
 "operationId": "OCGD03_prime_/api/opengate/{ver}/company/grade/{companyKey}/cashflow",
 "parameters": [
  {
   "name": "client-id",
   "in": "header",
   "description": "클라이언트ID",
   "required": true,
   "schema": {
    "type": "string"
   }
  },
  {
   "name": "client-secret",
   "in": "header",
   "description": "클라이언트 Secret",
   "required": true,
   "schema": {
    "type": "string"
   }
  },
  {
   "name": "companyKey",
   "in": "path",
   "description": "조회할 기업의 사업자번호, 법인번호, 업체코드 중 한개만 입력",
   "required": true,
   "schema": {
    "maxLength": 13.0,
    "pattern": "\\d{10}|\\d{13}|\\w{6}",
    "type": "string",
    "description": "조회 companyKey",
    "example": "1168115020"
   }
  },
  {
   "name": "startDate",
   "in": "query",
   "description": "일자 옵션선택 : 조회 시작일자(startDate <= 조건)",
   "required": false,
   "schema": {
    "maxLength": 8.0,
    "minLength": 8.0,
    "type": "string",
    "description": "일자 옵션선택 : 조회 시작일자(기준일자 필드의 <= 조건)",
    "format": "date-yyyymmdd"
   }
  },
  {
   "name": "endDate",
   "in": "query",
   "description": "일자 옵션선택 : 조회 종료일자(endDate >= 조건)",
   "required": false,
   "schema": {
    "maxLength": 8.0,
    "minLength": 8.0,
    "type": "string",
    "description": "일자 옵션선택 : 조회 종료일자(기준일자 필드의 >= 조건)",
    "format": "date-yyyymmdd"
   }
  },
  {
   "name": "pageNo",
   "in": "query",
   "description": "Page 옵션선택 : 페이지 번호",
   "required": false,
   "schema": {
    "minimum": 1.0,
    "type": "integer",
    "description": "PageNo",
    "format": "int32",
    "default": 1.0
   }
  },
  {
   "name": "pageSize",
   "in": "query",
   "description": "Page 옵션선택 : 페이지 사이즈",
   "required": false,
   "schema": {
    "maximum": 100.0,
    "minimum": 1.0,
    "type": "integer",
    "description": "PageSize",
    "format": "int32",
    "default": 20.0
   }
  }
 ],
 "responses": {
  "200": {
   "content": {
    "application/json": {
     "schema": {
      "type": "object",
      "properties": {
       "request": {
        "required": [
         "requestedKey",
         "requestedKeyType"
        ],
        "type": "object",
        "properties": {
         "requestedKey": {
          "maxLength": 13.0,
          "type": "string",
          "description": "요청 companyKey",
          "example": "1168115020"
         },
         "requestedKeyType": {
          "maxLength": 6.0,
          "type": "string",
          "description": "요청 Key 타입(bizno, crpno, upchecd)",
          "example": "bizno",
          "enum": [
           "BIZNO",
           "UPCHECD",
           "CRPNO"
          ]
         },
         "startDate": {
          "maxLength": 8.0,
          "minLength": 8.0,
          "type": "string",
          "description": "일자 옵션선택 : 조회 시작일자(기준일자 필드의 <= 조건)",
          "format": "date-yyyymmdd"
         },
         "endDate": {
          "maxLength": 8.0,
          "minLength": 8.0,
          "type": "string",
          "description": "일자 옵션선택 : 조회 종료일자(기준일자 필드의 >= 조건)",
          "format": "date-yyyymmdd"
         },
         "pageNo": {
          "minimum": 1.0,
          "type": "integer",
          "description": "PageNo",
          "format": "int32",
          "example": 1.0,
          "default": 1.0
         },
         "pageSize": {
          "maximum": 100.0,
          "minimum": 1.0,
          "type": "integer",
          "description": "PageSize",
          "format": "int32",
          "example": 20.0,
          "default": 20.0
         }
        },
        "description": "현금흐름등급 요청항목"
       },
       "data": {
        "required": [
         "cashFlowList",
         "listCount"
        ],
        "type": "object",
        "properties": {
         "message": {
          "type": "string",
          "description": "List 설명(데이터가 존재하지 않을 경우 등 이벤트 발생시 노출)"
         },
         "totalCount": {
          "type": "integer",
          "description": "전체건수: Page 옵션 사용시 결과출력",
          "format": "int32",
          "readOnly": true,
          "example": 13.0
         },
         "listCount": {
          "maximum": 100.0,
          "type": "integer",
          "description": "List 건수",
          "format": "int32",
          "example": 13.0,
          "default": 20.0
         },
         "cashFlowList": {
          "type": "array",
          "description": "현금흐름 등급 정보",
          "items": {
           "required": [
            "stacDate",
            "upchecd"
           ],
           "type": "object",
           "properties": {
            "upchecd": {
             "maxLength": 6.0,
             "type": "string",
             "description": "KISCODE",
             "example": "820610"
            },
            "stacDate": {
             "maxLength": 8.0,
             "type": "string",
             "description": "결산일자",
             "format": "date-yyyymmdd",
             "example": "20231231"
            },
            "btrStacDate": {
             "maxLength": 8.0,
             "type": "string",
             "description": "전기결산일자",
             "format": "date-yyyymmdd"
            },
            "cshflowgrd": {
             "maxLength": 3.0,
             "type": "string",
             "description": "현금흐름 등급",
             "example": "-  "
            },
            "cshflowgrdNm": {
             "maxLength": 250.0,
             "type": "string",
             "description": "현금흐름 등급명",
             "nullable": true,
             "example": " "
            },
            "crratdivcd": {
             "maxLength": 2.0,
             "type": "string",
             "description": "신용등급유형코드",
             "nullable": true,
             "example": "R1"
            },
            "crratdivnm": {
             "maxLength": 255.0,
             "type": "string",
             "description": "신용등급유형명",
             "example": " "
            },
            "grdStDate": {
             "maxLength": 8.0,
             "type": "string",
             "description": "등급시작일자",
             "format": "date-yyyymmdd",
             "nullable": true,
             "example": "20231231"
            },
            "grdEndDate": {
             "maxLength": 8.0,
             "type": "string",
             "description": "등급종료일자",
             "format": "date-yyyymmdd",
             "nullable": true,
             "example": " "
            },
            "cngBfCshflowgrd": {
             "maxLength": 3.0,
             "type": "string",
             "description": "변동전 현금흐름등급",
             "nullable": true
            }
           },
           "description": "현금흐름등급"
          }
         }
        },
        "description": "현금흐름 등급 결과"
       }
      }
     }
    }
   }
  }
 },
 "x-inzent-id": "6eefe2aa-f0d8-4618-87e9-f5a750e671d9"
}